---
const year = new Date().getFullYear();

const socials = [
  { href: 'https://github.com/matthusar', label: 'GitHub' },
  { href: 'https://linkedin.com/in/matthusar', label: 'LinkedIn' },
  { href: 'https://twitter.com/matthusar', label: 'Twitter / X' },
];
---

<footer class="border-t border-border mt-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-sm font-medium">Matt Husar</p>
        <p class="text-xs text-muted-foreground mt-0.5">
          &copy; {year} — Built with Astro, shadcn/ui & Tailwind CSS
        </p>
      </div>
      <div class="flex items-center gap-6">
        {
          socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-muted-foreground hover:text-foreground transition-colors"
            >
              {s.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
